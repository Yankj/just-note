#!/bin/bash
# OpenClaw Migration Pro - 专业版迁移工具

set -e

# 版本
VERSION="1.0.0"

# 配置
OPENCLAW_DIR="${HOME}/.openclaw"
WORKSPACE_DIR="${HOME}/openclaw/workspace"
BACKUP_DIR="${HOME}/openclaw-backup"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 排除模式（消耗品和不必要的文件）
# 核心原则：打包"我的东西"，不打包"消耗品"
EXCLUDE_PATTERN=(
  "node_modules/"     # 消耗品，到新家重新 npm install
  ".git/"             # 代码仓库（不需要）
  "completions/"      # 缓存（可重新生成）
  "*.log"             # 日志（不需要）
  ".DS_Store"         # 系统文件（不需要）
  "__pycache__/"      # Python 缓存（可重新生成）
)

# 帮助信息
show_help() {
  cat << EOF
OpenClaw Migration Pro v$VERSION - 像搬家一样迁移 OpenClaw 环境

用法：openclaw-migration-pro <command> [options]

命令:
  analyze [output-dir]           分析环境，生成 MANIFEST.json
  pack --output <dir> [options]  打包（支持增量/版本化/压缩）
  unpack --input <dir>           归位（在新环境恢复）
  transfer --input <dir> [opts]  自动传输到目标机器
  version                        显示版本号
  help                           显示此帮助

打包选项:
  --output <dir>         输出目录
  --versioned            版本化打包（带时间戳）
  --incremental <base>   增量打包（基于某个版本）
  --compress <format>    压缩格式：zip（默认）| tar.gz | none
  --no-send              禁用自动发送（默认自动发送）
  --exclude-credentials  排除敏感信息（默认启用）

示例:
  # 打包为 tar.gz（推荐）
  openclaw-migration-pro pack --output ~/openclaw-pack.tar.gz

  # 打包为 zip（Windows 友好）
  openclaw-migration-pro pack --compress zip --output ~/openclaw-pack.zip

  # 目录格式（不压缩，适合 rsync）
  openclaw-migration-pro pack --compress none --output ~/openclaw-pack/

传输选项:
  --input <dir>          输入目录
  --target <user@host>   目标机器
  --ssh-key <path>       SSH key 路径

示例:
  # 全量打包
  openclaw-migration-pro pack --output ~/openclaw-pack/

  # 版本化打包
  openclaw-migration-pro pack --versioned --output ~/packs/

  # 增量打包（基于某个版本）
  openclaw-migration-pro pack --incremental ~/packs/base/ --output ~/packs/delta/

  # 自动传输
  openclaw-migration-pro transfer --input ~/packs/ --target user@new-pc:~/

EOF
}

# 从 SKILL.md 提取维护的目录
extract_maintains() {
  local skill_dir="$1"
  local skill_name=$(basename "$skill_dir")
  
  # 检查是否有 memory/<skill-name>/ 目录
  if [ -d "$WORKSPACE_DIR/memory/$skill_name" ]; then
    echo "\"memory/$skill_name/\""
  else
    echo ""
  fi
}

# 分析环境（增强版）
cmd_analyze() {
  local output_dir="${1:-${HOME}/openclaw-migrate}"
  
  echo -e "${BLUE}🔍 分析 OpenClaw 环境...${NC}"
  echo ""
  
  mkdir -p "$output_dir"
  
  # 统计工作区 Skills
  echo "📦 分析工作区 Skills..."
  local workspace_skills=()
  local associations=()
  if [ -d "$WORKSPACE_DIR/skills" ]; then
    for skill_dir in "$WORKSPACE_DIR/skills"/*/; do
      if [ -d "$skill_dir" ]; then
        local skill_name=$(basename "$skill_dir")
        local maintains=$(extract_maintains "$skill_dir")
        workspace_skills+=("$skill_name")
        if [ -n "$maintains" ]; then
          associations+=("{\"skill\":\"$skill_name\",\"maintains\":[$maintains]}")
          echo "   - $skill_name (维护：$maintains)"
        else
          echo "   - $skill_name"
        fi
      fi
    done
  fi
  echo "   ✅ 工作区 Skills: ${#workspace_skills[@]} 个"
  echo ""
  
  # 统计 ClawHub Skills
  echo "📦 分析 ClawHub Skills..."
  local clawhub_skills=()
  if [ -d "$OPENCLAW_DIR/skills" ]; then
    for skill_dir in "$OPENCLAW_DIR/skills"/*/; do
      if [ -d "$skill_dir" ]; then
        local skill_name=$(basename "$skill_dir")
        # 检查工作区是否已有
        if [[ ! " ${workspace_skills[@]} " =~ " ${skill_name} " ]]; then
          clawhub_skills+=("$skill_name")
        fi
      fi
    done
  fi
  echo "   ✅ ClawHub Skills: ${#clawhub_skills[@]} 个（可重新安装）"
  echo ""
  
  # 统计 Memory
  echo "📦 分析 Memory..."
  local memory_files=$(find "$WORKSPACE_DIR/memory" -name "*.md" 2>/dev/null | wc -l)
  local memory_size=$(du -sh "$WORKSPACE_DIR/memory" 2>/dev/null | cut -f1)
  echo "   文件数：$memory_files 个"
  echo "   大小：$memory_size"
  echo ""
  
  # 统计 Cron
  echo "📦 分析 Cron Jobs..."
  local cron_jobs=$(ls -1 "$OPENCLAW_DIR/cron/"*.json 2>/dev/null | wc -l)
  echo "   任务数：$cron_jobs 个"
  echo ""
  
  # 检查敏感信息
  echo "🔒 检查敏感信息..."
  if [ -d "$OPENCLAW_DIR/credentials" ]; then
    local cred_count=$(ls -1 "$OPENCLAW_DIR/credentials/" 2>/dev/null | wc -l)
    echo "   ⚠️  credentials: $cred_count 个文件（将排除，不打包）"
  fi
  if [ -f "$OPENCLAW_DIR/.env" ]; then
    echo "   ⚠️  .env: 存在（将排除，不打包）"
  fi
  echo ""
  
  # 生成 MANIFEST.json
  local workspace_json=$(printf '"%s"\n' "${workspace_skills[@]}" | paste -sd, | sed 's/^/[/;s/$/]/')
  local clawhub_json=$(printf '"%s"\n' "${clawhub_skills[@]}" | paste -sd, | sed 's/^/[/;s/$/]/')
  local associations_json=$(printf '%s\n' "${associations[@]}" | paste -sd, | sed 's/^/[/;s/$/]/')
  
  cat > "$output_dir/MANIFEST.json" << EOF
{
  "skills": {
    "pack": $workspace_json,
    "reinstall": $clawhub_json
  },
  "memory": {
    "files": $memory_files,
    "size": "$memory_size"
  },
  "cron": {
    "jobs": $cron_jobs
  },
  "associations": $associations_json,
  "excluded": [
    "credentials/",
    "*.key",
    "*.pem",
    "*.env",
    "node_modules/",
    "completions/",
    "*.log"
  ],
  "generated_at": "$(date -Iseconds)"
}
EOF
  
  echo -e "${GREEN}✅ 分析完成${NC}"
  echo ""
  echo "MANIFEST: $output_dir/MANIFEST.json"
  echo ""
  echo "下一步：打包"
  echo "  openclaw-migrate pack --output ~/openclaw-pack/"
  echo ""
  echo "可选：版本化打包"
  echo "  openclaw-migrate pack --versioned --output ~/packs/"
}

# 打包（完整优化版）
cmd_pack() {
  local output_dir=""
  local versioned=false
  local incremental_base=""
  local compress_format="zip"  # 默认压缩为 zip（Mac/Windows 兼容）
  local auto_send=true  # 默认自动发送文件
  
  # 解析参数
  while [[ $# -gt 0 ]]; do
    case $1 in
      --output)
        output_dir="$2"
        shift 2
        ;;
      --versioned)
        versioned=true
        shift
        ;;
      --incremental)
        incremental_base="$2"
        shift 2
        ;;
      --compress)
        compress_format="$2"
        shift 2
        ;;
      --no-send)
        auto_send=false
        shift
        ;;
      *)
        shift
        ;;
    esac
  done
  
  # 确定输出路径
  local temp_dir=""
  local final_output=""
  
  if [ "$compress_format" = "none" ]; then
    # 目录格式
    if [ -z "$output_dir" ]; then
      if [ "$versioned" = true ]; then
        output_dir="${BACKUP_DIR}/openclaw-pack-$(date +%Y-%m-%d-%H%M%S)"
      else
        output_dir="${BACKUP_DIR}/$(date +%Y-%m-%d-%H%M%S)"
      fi
    fi
    temp_dir="$output_dir"
    final_output="$output_dir"
  elif [ "$compress_format" = "tar.gz" ] || [ "$compress_format" = "tgz" ]; then
    # tar.gz 格式
    if [ -z "$output_dir" ]; then
      if [ "$versioned" = true ]; then
        output_dir="${BACKUP_DIR}/openclaw-pack-$(date +%Y-%m-%d-%H%M%S).tar.gz"
      else
        output_dir="${BACKUP_DIR}/openclaw-pack.tar.gz"
      fi
    fi
    # 确保是 .tar.gz 后缀
    if [[ ! "$output_dir" =~ \.tar\.gz$ ]] && [[ ! "$output_dir" =~ \.tgz$ ]]; then
      output_dir="${output_dir}.tar.gz"
    fi
    temp_dir="${BACKUP_DIR}/.pack-temp-$$"
    final_output="$output_dir"
  elif [ "$compress_format" = "zip" ]; then
    # zip 格式
    if [ -z "$output_dir" ]; then
      if [ "$versioned" = true ]; then
        output_dir="${BACKUP_DIR}/openclaw-pack-$(date +%Y-%m-%d-%H%M%S).zip"
      else
        output_dir="${BACKUP_DIR}/openclaw-pack.zip"
      fi
    fi
    # 确保是 .zip 后缀
    if [[ ! "$output_dir" =~ \.zip$ ]]; then
      output_dir="${output_dir}.zip"
    fi
    temp_dir="${BACKUP_DIR}/.pack-temp-$$"
    final_output="$output_dir"
  else
    echo -e "${RED}❌ 错误：不支持的压缩格式：$compress_format${NC}"
    echo "支持的格式：tar.gz, zip, none"
    exit 1
  fi
  
  echo -e "${BLUE}📦 开始打包 OpenClaw...${NC}"
  echo ""
  
  # 创建临时目录（压缩模式）或最终目录（非压缩模式）
  mkdir -p "$temp_dir"
  
  # 构建 rsync 排除参数
  local exclude_args=""
  for pattern in "${EXCLUDE_PATTERN[@]}"; do
    exclude_args="$exclude_args --exclude=$pattern"
  done
  
  # 打包 Skills
  echo "📦 打包 Skills..."
  mkdir -p "$temp_dir/skills"
  
  # 复制工作区 Skills（本地创建的）
  if [ -d "$WORKSPACE_DIR/skills" ]; then
    if [ -n "$incremental_base" ] && [ -d "$incremental_base/skills/workspace" ]; then
      # 增量打包
      rsync -av --delete $exclude_args \
        --link-dest="$incremental_base/skills/workspace" \
        "$WORKSPACE_DIR/skills/" \
        "$temp_dir/skills/workspace/" 2>/dev/null || true
    else
      # 全量打包
      rsync -av --delete $exclude_args \
        "$WORKSPACE_DIR/skills/" \
        "$temp_dir/skills/workspace/" 2>/dev/null || true
    fi
    local workspace_count=$(ls -1 "$temp_dir/skills/workspace" 2>/dev/null | wc -l)
    echo "   ✅ 工作区 Skills: $workspace_count 个"
  fi
  
  # 复制 ClawHub Skills（可选，如果用户想完整备份）
  if [ -d "$OPENCLAW_DIR/skills" ]; then
    rsync -av $exclude_args \
      "$OPENCLAW_DIR/skills/" \
      "$temp_dir/skills/clawhub/" 2>/dev/null || true
    local clawhub_count=$(ls -1 "$temp_dir/skills/clawhub" 2>/dev/null | wc -l)
    echo "   ✅ ClawHub Skills: $clawhub_count 个（可重新安装）"
  fi
  
  echo ""
  
  # 打包 Memory
  echo "📦 打包 Memory..."
  mkdir -p "$temp_dir/memory"
  if [ -d "$WORKSPACE_DIR/memory" ]; then
    if [ -n "$incremental_base" ] && [ -d "$incremental_base/memory" ]; then
      # 增量打包
      rsync -av --delete $exclude_args \
        --link-dest="$incremental_base" \
        "$WORKSPACE_DIR/memory/" \
        "$temp_dir/memory/" 2>/dev/null || true
    else
      # 全量打包
      rsync -av --delete $exclude_args \
        "$WORKSPACE_DIR/memory/" \
        "$temp_dir/memory/" 2>/dev/null || true
    fi
    local memory_files=$(find "$temp_dir/memory" -name "*.md" | wc -l)
    local memory_size=$(du -sh "$temp_dir/memory" 2>/dev/null | cut -f1)
    echo "   ✅ Memory: $memory_files 个文件 ($memory_size)"
  fi
  
  echo ""
  
  # 打包配置（排除敏感信息）
  echo "📦 打包配置（排除敏感信息）..."
  mkdir -p "$temp_dir/config"
  
  # OpenClaw 配置
  if [ -f "$OPENCLAW_DIR/openclaw.json" ]; then
    cp "$OPENCLAW_DIR/openclaw.json" "$temp_dir/config/"
  fi
  
  # 工作区配置
  for file in SOUL.md USER.md IDENTITY.md TOOLS.md AGENTS.md HEARTBEAT.md; do
    if [ -f "$WORKSPACE_DIR/$file" ]; then
      cp "$WORKSPACE_DIR/$file" "$temp_dir/config/"
    fi
  done
  
  echo "   ✅ 配置：已打包"
  echo "   ⚠️  已排除：credentials/, *.env, *.key（需要重新配置）"
  echo ""
  
  # 打包 Cron
  echo "📦 打包 Cron Jobs..."
  mkdir -p "$temp_dir/cron"
  if [ -d "$OPENCLAW_DIR/cron" ]; then
    cp -r "$OPENCLAW_DIR/cron"/* "$temp_dir/cron/" 2>/dev/null || true
    local cron_count=$(ls -1 "$temp_dir/cron/"*.json 2>/dev/null | wc -l)
    echo "   ✅ Cron: $cron_count 个"
  fi
  
  echo ""
  
  # 创建备份清单
  cat > "$temp_dir/BACKUP_INFO.md" << EOF
# OpenClaw 迁移包

**创建时间**: $(date -Iseconds)
**版本**: $([ "$versioned" = true ] && echo "版本化" || echo "标准")
**增量**: $([ -n "$incremental_base" ] && echo "基于：$incremental_base" || echo "全量")

## 内容

- Skills: $(ls -1 "$temp_dir/skills/workspace" 2>/dev/null | wc -l) 个（工作区）
- Skills: $(ls -1 "$temp_dir/skills/clawhub" 2>/dev/null | wc -l) 个（ClawHub，可重新安装）
- Memory: $(find "$temp_dir/memory" -name "*.md" 2>/dev/null | wc -l) 个文件
- Cron: $(ls -1 "$temp_dir/cron/"*.json 2>/dev/null | wc -l) 个
- 配置：openclaw.json + 工作区配置

## 排除内容（安全）

- ❌ credentials/ (API Keys)
- ❌ *.env (环境变 量)
- ❌ *.key, *.pem (证书)
- ❌ node_modules/ (可重新安装)
- ❌ completions/ (缓存)
- ❌ *.log (日志)

## 归位命令

\`\`\`bash
openclaw-migration-pro unpack --input $final_output
\`\`\`

## 自动传输

\`\`\`bash
# 传输到目标机器
openclaw-migration-pro transfer --input $final_output --target user@new-pc:~/
\`\`\`

## 注意事项

1. API Keys 和 Channel 配置未包含（需要重新配置）
2. 归位后请重启 OpenClaw Gateway
3. ClawHub Skills 可以重新安装：npx clawhub install <skill-name>
EOF
  
  # 压缩处理
  if [ "$compress_format" != "none" ]; then
    echo ""
    echo -e "${BLUE}🗜️  正在压缩为 $compress_format 格式...${NC}"
    
    # 确保父目录存在
    mkdir -p "$(dirname "$final_output")"
    
    if [ "$compress_format" = "tar.gz" ] || [ "$compress_format" = "tgz" ]; then
      # 使用 tar.gz 压缩
      tar -czf "$final_output" -C "$(dirname "$temp_dir")" "$(basename "$temp_dir")" 2>/dev/null
      local compress_size=$(du -sh "$final_output" | cut -f1)
      echo -e "${GREEN}✅ 压缩完成${NC}"
    elif [ "$compress_format" = "zip" ]; then
      # 使用 zip 压缩（Mac/Windows 兼容）
      cd "$(dirname "$temp_dir")" && zip -rq "$final_output" "$(basename "$temp_dir")" 2>/dev/null
      local compress_size=$(du -sh "$final_output" | cut -f1)
      echo -e "${GREEN}✅ 压缩完成${NC}"
      cd - > /dev/null
    fi
    
    # 清理临时目录
    rm -rf "$temp_dir"
    
    # 计算压缩率
    local original_size=$(du -sh "$temp_dir" 2>/dev/null | cut -f1 || echo "N/A")
    echo ""
    echo -e "${GREEN}✅ 打包完成：$final_output${NC}"
    echo ""
    echo "压缩后大小：$compress_size"
    echo "原始大小：$original_size"
    echo "格式：$compress_format"
    
    # 自动发送文件（如果启用）
    if [ "$auto_send" = true ]; then
      echo ""
      echo -e "${BLUE}📤 正在发送文件到当前频道...${NC}"
      
      # 获取文件名
      local filename=$(basename "$final_output")
      local filesize=$(du -h "$final_output" | cut -f1)
      
      # 创建发送消息
      local message="📦 **OpenClaw 迁移备份包** ($filesize)

**内容：**
- 工作区 Skills
- ClawHub Skills
- Memory 文件
- 配置文件
- Cron Jobs

**格式：** $compress_format（Mac/Windows 兼容）

**解压命令：**
\`\`\`bash
# Mac/Linux
unzip $filename -d ~/openclaw-backup/

# Windows
右键 → 全部解压
\`\`\`

**归位命令：**
\`\`\`bash
openclaw-migration-pro unpack --input ~/openclaw-backup/
\`\`\`"
      
      # 使用 openclaw exec 发送消息（如果可用）
      # 注意：这需要 openclaw CLI 支持 message 命令
      # 如果不可用，会静默失败
      if command -v openclaw &> /dev/null; then
        # 尝试通过 openclaw CLI 发送（如果支持）
        # 这个命令可能不可用，所以忽略错误
        openclaw message send --file "$final_output" --message "$message" 2>/dev/null || true
      fi
      
      # 输出发送提示
      echo -e "${GREEN}✅ 文件已准备发送${NC}"
      echo ""
      echo "文件路径：$final_output"
      echo ""
      echo "⚠️  如果文件没有自动发送，请手动使用 message 工具发送："
      echo "   message action=send filePath=$final_output"
    fi
  else
    # 目录格式，直接输出
    local backup_size=$(du -sh "$final_output" | cut -f1)
    local base_size="N/A"
    if [ -n "$incremental_base" ]; then
      base_size=$(du -sh "$incremental_base" | cut -f1)
    fi
    
    echo -e "${GREEN}✅ 打包完成：$final_output${NC}"
    echo ""
    echo "备份大小：$backup_size"
    if [ -n "$incremental_base" ]; then
      echo "基础版本：$base_size"
      echo "节省空间：$(echo "scale=2; (1 - $(du -s "$final_output" | cut -f1) / $(du -s "$incremental_base" | cut -f1)) * 100" | bc)%"
    fi
  fi
  
  echo ""
  echo "归位命令:"
  echo "  openclaw-migration-pro unpack --input $final_output"
  echo ""
  echo "自动传输:"
  echo "  openclaw-migration-pro transfer --input $final_output --target user@host:~/"
  echo ""
  echo "网盘分享:"
  echo "  上传 $final_output 到网盘，然后在目标机器下载并归位"
}

# 自动传输
cmd_transfer() {
  local input_dir=""
  local target=""
  local ssh_key=""
  
  # 解析参数
  while [[ $# -gt 0 ]]; do
    case $1 in
      --input)
        input_dir="$2"
        shift 2
        ;;
      --target)
        target="$2"
        shift 2
        ;;
      --ssh-key)
        ssh_key="$2"
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  
  if [ -z "$input_dir" ]; then
    echo -e "${RED}❌ 错误：请指定输入目录 (--input)${NC}"
    exit 1
  fi
  
  if [ -z "$target" ]; then
    echo -e "${RED}❌ 错误：请指定目标机器 (--target)${NC}"
    exit 1
  fi
  
  if [ ! -d "$input_dir" ]; then
    echo -e "${RED}❌ 错误：目录不存在：$input_dir${NC}"
    exit 1
  fi
  
  echo -e "${BLUE}🚀 开始自动传输...${NC}"
  echo ""
  echo "源目录：$input_dir"
  echo "目标：$target"
  echo ""
  
  # 构建 SSH 参数
  local ssh_args=""
  if [ -n "$ssh_key" ]; then
    ssh_args="-i $ssh_key"
  fi
  
  # 测试连接
  echo "🔍 测试 SSH 连接..."
  if ssh $ssh_args -o ConnectTimeout=5 -o BatchMode=yes "$target" "echo OK" > /dev/null 2>&1; then
    echo "   ✅ SSH 连接成功"
  else
    echo "   ❌ SSH 连接失败"
    echo ""
    echo "请检查:"
    echo "  1. 目标机器是否在线"
    echo "  2. SSH key 是否正确"
    echo "  3. 防火墙是否允许 SSH"
    echo ""
    exit 1
  fi
  echo ""
  
  # 传输
  echo "📦 传输数据..."
  rsync -avz -e "ssh $ssh_args" \
    --progress \
    "$input_dir/" \
    "$target:openclaw-pack/"
  
  echo ""
  echo -e "${GREEN}✅ 传输完成！${NC}"
  echo ""
  echo "在目标机器上归位:"
  echo "  ssh $target"
  echo "  openclaw-migrate unpack --input ~/openclaw-pack/"
}

# 归位（完整版）
cmd_unpack() {
  local input_dir=""
  local temp_dir=""
  
  # 解析参数
  while [[ $# -gt 0 ]]; do
    case $1 in
      --input)
        input_dir="$2"
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  
  if [ -z "$input_dir" ]; then
    echo -e "${RED}❌ 错误：请指定输入目录 (--input)${NC}"
    exit 1
  fi
  
  # 检查输入类型（压缩包或目录）
  local is_compressed=false
  local extract_dir=""
  
  if [ -f "$input_dir" ]; then
    # 是文件，检查是否为压缩包
    if [[ "$input_dir" =~ \.tar\.gz$ ]] || [[ "$input_dir" =~ \.tgz$ ]]; then
      is_compressed=true
      extract_dir="${BACKUP_DIR}/.unpack-temp-$$"
      echo -e "${BLUE}📦 检测到 tar.gz 压缩包，正在解压...${NC}"
      mkdir -p "$extract_dir"
      tar -xzf "$input_dir" -C "$extract_dir" 2>/dev/null
      # 找到解压后的目录
      temp_dir=$(find "$extract_dir" -maxdepth 1 -type d | head -1)
      if [ -n "$temp_dir" ] && [ "$temp_dir" != "$extract_dir" ]; then
        input_dir="$temp_dir"
      else
        input_dir="$extract_dir"
      fi
      echo -e "${GREEN}✅ 解压完成${NC}"
    elif [[ "$input_dir" =~ \.zip$ ]]; then
      is_compressed=true
      extract_dir="${BACKUP_DIR}/.unpack-temp-$$"
      echo -e "${BLUE}📦 检测到 zip 压缩包，正在解压...${NC}"
      mkdir -p "$extract_dir"
      unzip -q "$input_dir" -d "$extract_dir" 2>/dev/null
      # 找到解压后的目录
      temp_dir=$(find "$extract_dir" -maxdepth 1 -type d | head -1)
      if [ -n "$temp_dir" ] && [ "$temp_dir" != "$extract_dir" ]; then
        input_dir="$temp_dir"
      else
        input_dir="$extract_dir"
      fi
      echo -e "${GREEN}✅ 解压完成${NC}"
    else
      echo -e "${RED}❌ 错误：未知文件格式：$input_dir${NC}"
      echo "支持的文件格式：.tar.gz, .tgz, .zip 或目录"
      exit 1
    fi
  elif [ ! -d "$input_dir" ]; then
    echo -e "${RED}❌ 错误：目录不存在：$input_dir${NC}"
    exit 1
  fi
  
  echo -e "${BLUE}🏠 开始归位 OpenClaw...${NC}"
  echo ""
  
  # 检查 OpenClaw 是否安装
  if ! command -v openclaw &> /dev/null; then
    echo -e "${YELLOW}⚠️  OpenClaw 未安装${NC}"
    echo ""
    echo "请先安装 OpenClaw:"
    echo "  curl -fsSL https://openclaw.ai/install.sh | bash"
    echo ""
    exit 1
  fi
  
  # 恢复 Skills
  echo "📦 恢复 Skills..."
  if [ -d "$input_dir/skills/workspace" ]; then
    mkdir -p "$WORKSPACE_DIR/skills"
    rsync -av "$input_dir/skills/workspace/" "$WORKSPACE_DIR/skills/" 2>/dev/null || true
    local workspace_count=$(ls -1 "$WORKSPACE_DIR/skills" | wc -l)
    echo "   ✅ 工作区 Skills: $workspace_count 个"
  fi
  
  if [ -d "$input_dir/skills/clawhub" ]; then
    mkdir -p "$OPENCLAW_DIR/skills"
    rsync -av "$input_dir/skills/clawhub/" "$OPENCLAW_DIR/skills/" 2>/dev/null || true
    local clawhub_count=$(ls -1 "$OPENCLAW_DIR/skills" | wc -l)
    echo "   ✅ ClawHub Skills: $clawhub_count 个"
  fi
  
  # 重新安装依赖
  echo ""
  echo "📦 安装 Skills 依赖..."
  local installed=0
  for skill_dir in "$WORKSPACE_DIR/skills/*/"; do
    if [ -f "$skill_dir/package.json" ]; then
      local skill_name=$(basename "$skill_dir")
      if [ ! -d "$skill_dir/node_modules" ]; then
        echo "   - $skill_name: npm install..."
        cd "$skill_dir" && npm install --silent 2>/dev/null && ((installed++)) || true
      fi
    fi
  done
  if [ $installed -gt 0 ]; then
    echo "   ✅ 已安装 $installed 个 Skills 的依赖"
  else
    echo "   ✅ 无需安装依赖"
  fi
  
  echo ""
  
  # 恢复 Memory
  echo "📦 恢复 Memory..."
  if [ -d "$input_dir/memory" ]; then
    mkdir -p "$WORKSPACE_DIR/memory"
    rsync -av "$input_dir/memory/" "$WORKSPACE_DIR/memory/" 2>/dev/null || true
    local memory_files=$(find "$WORKSPACE_DIR/memory" -name "*.md" | wc -l)
    echo "   ✅ Memory: $memory_files 个文件"
  fi
  
  echo ""
  
  # 恢复配置
  echo "📦 恢复配置..."
  if [ -d "$input_dir/config" ]; then
    # OpenClaw 配置
    if [ -f "$input_dir/config/openclaw.json" ]; then
      cp "$input_dir/config/openclaw.json" "$OPENCLAW_DIR/"
    fi
    
    # 工作区配置
    for file in SOUL.md USER.md IDENTITY.md TOOLS.md AGENTS.md HEARTBEAT.md; do
      if [ -f "$input_dir/config/$file" ]; then
        cp "$input_dir/config/$file" "$WORKSPACE_DIR/"
      fi
    done
    
    echo "   ✅ 配置：已恢复"
  fi
  
  echo ""
  
  # 恢复 Cron
  echo "📦 恢复 Cron Jobs..."
  if [ -d "$input_dir/cron" ]; then
    mkdir -p "$OPENCLAW_DIR/cron"
    cp -r "$input_dir/cron"/* "$OPENCLAW_DIR/cron/" 2>/dev/null || true
    local cron_count=$(ls -1 "$OPENCLAW_DIR/cron/"*.json 2>/dev/null | wc -l)
    echo "   ✅ Cron: $cron_count 个"
  fi
  
  echo ""
  echo -e "${GREEN}✅ 归位完成！${NC}"
  echo ""
  echo "请重启 OpenClaw Gateway:"
  echo "  openclaw gateway restart"
  echo ""
  echo "请重新配置:"
  echo "  - API Keys (openclaw config set)"
  echo "  - Channel 配置"
  
  # 清理临时目录
  if [ -n "$extract_dir" ] && [ -d "$extract_dir" ]; then
    rm -rf "$extract_dir"
  fi
}

# 显示版本
show_version() {
  echo "OpenClaw Migration Pro v$VERSION"
}

# 主函数
main() {
  local command="${1:-help}"
  shift || true
  
  case $command in
    analyze)
      cmd_analyze "$@"
      ;;
    pack)
      cmd_pack "$@"
      ;;
    unpack)
      cmd_unpack "$@"
      ;;
    transfer)
      cmd_transfer "$@"
      ;;
    version|--version|-V)
      show_version
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      echo -e "${RED}❌ 未知命令：$command${NC}"
      echo ""
      show_help
      exit 1
      ;;
  esac
}

# 运行
main "$@"
