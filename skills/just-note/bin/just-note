        income) type_icon="💰" ;;
        diary) type_icon="📝" ;;
        task) type_icon="✅" ;;
        quote) type_icon="💬" ;;
        *) type_icon="📌" ;;
      esac
      echo "- $type_icon $type: **$type_count** 条"
    fi
  done
  echo ""
  
  # 本月趋势（与上月对比）
  echo "### 📈 趋势分析"
  echo ""
  echo "_对比分析中..._"
  echo ""
  
  # 本月亮点（AI 生成）
  echo "### ✨ 本月亮点"
  echo ""
