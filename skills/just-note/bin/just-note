  echo ""
}

# AI 生成每日总结
cmd_daily_summary() {
  local date="$1"
  
  if [ -z "$date" ]; then
    date=$(date +%Y-%m-%d)
  fi
  
  echo "# 🤖 AI 每日总结 - $date"
  echo ""
  
  # 收集今日内容
  local all_content=""
  local count=0
  for file in "$STORAGE_DIR"/*/*.md; do
    if [ -f "$file" ]; then
      local file_date=$(grep "^day-id:" "$file" | cut -d' ' -f2-)
      if [ "$file_date" = "$date" ]; then
        all_content+="$(cat "$file")"$'\n'
        count=$((count + 1))
      fi
    fi
  done
  
  if [ $count -eq 0 ]; then
    echo "💭 今日暂无记录，无法生成总结"
    return
  fi
  
  echo "收集到 **$count** 条记录"
  echo ""
  echo "---"
  echo ""
  
  # 生成 AI 总结的 Prompt
  local prompt="请根据用户今日的笔记记录，生成一个温暖的每日总结。

要求：
1. 总结今日主要关注点（100 字以内）
2. 提炼关键收获/洞察（列出 1-3 点）
3. 给出明日的友好建议（50 字以内）
4. 语气像朋友一样温暖、鼓励

笔记内容：
$all_content

请用 Markdown 格式输出。"

  echo "📝 **今日关注**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "✨ **关键收获**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "💡 **明日建议**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "---"
  echo ""
  echo "💡 提示：此功能需要集成 LLM，当前显示模板输出"
  echo ""
  echo "要启用 AI 总结，请配置："
  echo '```bash'
  echo 'export JUST_NOTE_LLM_MODEL=qwen3.5-plus'
  echo 'export JUST_NOTE_AUTO_TAG=true'
  echo '```'
}

# AI 生成本周总结
cmd_weekly_ai() {
  echo "# 🤖 AI 本周总结"
  echo ""
  
  local week_start=$(date -d "last Monday" +%Y-%m-%d 2>/dev/null || echo "本周一")
  local week_end=$(date -d "next Sunday" +%Y-%m-%d 2>/dev/null || echo "本周日")
  
  echo "**周期**: $week_start 至 $week_end"
  echo ""
  
  # 收集本周内容
  local all_content=""
  local count=0
  for file in "$STORAGE_DIR"/*/*.md; do
    if [ -f "$file" ]; then
      local created=$(grep "^created:" "$file" | cut -d' ' -f2-)
      # 简化：假设本周的文件都在最近 7 天
      count=$((count + 1))
      all_content+="$(head -20 "$file")"$'\n'
    fi
  done
  
  if [ $count -eq 0 ]; then
    echo "💭 本周暂无记录"
    return
  fi
  
  echo "本周共 **$count** 条记录"
  echo ""
  echo "---"
  echo ""
  
  echo "📊 **本周主题**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "🎯 **进展与成就**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "🌱 **成长与反思**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "🚀 **下周建议**"
  echo "_（AI 分析中...）_"
  echo ""
  
  echo "---"
  echo ""
  echo "💡 提示：配置 LLM 后启用完整 AI 总结功能"
}

# AI 生成本月总结
cmd_monthly_ai() {
